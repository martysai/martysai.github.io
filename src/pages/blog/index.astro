---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

type Post = Awaited<ReturnType<typeof getCollection<'posts'>>>[number];

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => Number(b.data.pubDate ?? 0) - Number(a.data.pubDate ?? 0));
const formatDate = (date?: Date) => date ? new Intl.DateTimeFormat('en', { month: 'long', day: 'numeric', year: 'numeric' }).format(date) : '';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const slugOf = (post: { id: string }) => post.id.replace(/\.(md|mdx)$/, '').toLowerCase();
const cleanExcerpt = (body = '') => body
  .replace(/^---[\s\S]*?---/, '')
  .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
  .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
  .replace(/<[^>]+>/g, '')
  .replace(/[#*_`>\[\]()]/g, '')
  .replace(/\s+/g, ' ')
  .trim();
const excerptOf = (post: Post) => {
  const text = post.data.description ?? cleanExcerpt(post.body ?? '');
  return text ? `${text.slice(0, 170).replace(/\s+\S*$/, '')}…` : 'Read the blog post.';
};
const imageOf = (post: Post) => post.data.heroImage ?? (post.body ?? '').match(/!\[[^\]]*\]\(([^)]+)\)/)?.[1] ?? '';
---
<BaseLayout title="Blog posts">
  <section class="site-shell hero compact-hero">
    <div class="eyebrow">Archive</div>
    <h1>Blog posts, projects, and field notes.</h1>
    <p>Conference notes, production ML write-ups, small-model engineering, prompt optimization, and personal research logs.</p>
  </section>
  <section class="site-shell">
    <div class="grid archive-grid">
      {posts.map((post) => (
        <a class="card" href={`${base}/blog/${slugOf(post)}/`}>
          {imageOf(post) && <img class="card-media" src={imageOf(post)} alt="" loading="lazy" />}
          <div class="card-body">
            <div>
              <div class="date">{formatDate(post.data.pubDate)}</div>
              <h2>{post.data.title}</h2>
            </div>
            <p>{excerptOf(post)}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
